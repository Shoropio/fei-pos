<UserControl x:Class="FeiPos.Presentation.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019">
    
    <ScrollViewer Margin="20">
        <StackPanel>
            <TextBlock Text="Resumen de Operaciones" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,25"/>

            <!-- Tarjetas de Métricas -->
            <UniformGrid Columns="3" Margin="0,0,0,30">
                <Border Background="{StaticResource AppPanelBrush}" Margin="5" Padding="20" CornerRadius="8">
                    <StackPanel>
                        <ui:SymbolIcon Symbol="List" Margin="0,0,0,10" HorizontalAlignment="Left"/>
                        <TextBlock Text="Ventas del Día" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        <TextBlock Text="{Binding DailySales, StringFormat=₡{0:N2}}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource SystemAccentColorBrush}"/>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource AppPanelBrush}" Margin="5" Padding="20" CornerRadius="8">
                    <StackPanel>
                        <ui:SymbolIcon Symbol="Calculator" Margin="0,0,0,10" HorizontalAlignment="Left"/>
                        <TextBlock Text="IVA Recaudado" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        <TextBlock Text="{Binding DailyTax, StringFormat=₡{0:N2}}" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource AppPanelBrush}" Margin="5" Padding="20" CornerRadius="8">
                    <StackPanel>
                        <ui:SymbolIcon Symbol="Tag" Margin="0,0,0,10" HorizontalAlignment="Left"/>
                        <TextBlock Text="Transacciones" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        <TextBlock Text="{Binding TotalTransactions}" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Ranking de Productos -->
            <TextBlock Text="Top 5 Productos Más Vendidos" Style="{StaticResource SubtitleTextBlockStyle}" Margin="5,0,0,15"/>
            <Border Background="{StaticResource AppPanelBrush}" CornerRadius="8" Padding="10">
                <ItemsControl ItemsSource="{Binding TopProducts}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="10,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                    <ProgressBar Value="{Binding Quantity}" Maximum="100" Height="4" Margin="0,5,0,0"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding Total, StringFormat=₡{0:N2}}" VerticalAlignment="Center" Margin="20,0,0,0"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
