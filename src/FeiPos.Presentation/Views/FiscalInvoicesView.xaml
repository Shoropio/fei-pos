<UserControl x:Class="FeiPos.Presentation.Views.FiscalInvoicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="1.3*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Facturas fiscales"
                       Style="{StaticResource TitleTextBlockStyle}"
                       VerticalAlignment="Center"
                       Margin="0,0,22,0"/>

            <DatePicker Grid.Column="1"
                        SelectedDate="{Binding FromDate}"
                        Width="130"
                        VerticalAlignment="Center"
                        Margin="0,0,15,0"/>
            <DatePicker Grid.Column="2"
                        SelectedDate="{Binding ToDate}"
                        Width="130"
                        VerticalAlignment="Center"
                        Margin="0,0,15,0"/>
            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
                <ComboBox ItemsSource="{Binding InvoiceStatuses}"
                          SelectedItem="{Binding SelectedInvoiceStatus}"
                          Width="140"
                          Margin="0,0,10,0"/>
                <ComboBox ItemsSource="{Binding FiscalStatuses}"
                          SelectedItem="{Binding SelectedFiscalStatus}"
                          Width="140"
                          Margin="0,0,0,0"/>
            </StackPanel>
            <TextBox Grid.Column="4"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     MinWidth="280"
                     VerticalAlignment="Center"
                     VerticalContentAlignment="Center"
                     Margin="0,0,20,0"
                     ToolTip="Cliente, identificacion, consecutivo, clave o metodo"/>
            <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Buscar" Command="{Binding LoadInvoicesCommand}" Margin="0,0,10,0"/>
                <Button Content="Reimprimir" Command="{Binding ReprintSelectedCommand}" Margin="0,0,10,0"/>
                <Button Content="Reenviar a Hacienda" Command="{Binding ResendSelectedCommand}" Margin="0,0,10,0" ToolTip="Re-encolar para envío si falló"/>
                <Button Content="Anular / NC" Command="{Binding CancelSelectedCommand}"/>
            </StackPanel>
        </Grid>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Invoices}"
                  SelectedItem="{Binding SelectedInvoice}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Fecha" Binding="{Binding CreatedAt, StringFormat=g}" Width="140"/>
                <DataGridTextColumn Header="Cliente" Binding="{Binding CustomerName}" Width="*"/>
                <DataGridTextColumn Header="Consecutivo" Binding="{Binding ConsecutiveNumber}" Width="160"/>
                <DataGridTextColumn Header="Clave Hacienda" Binding="{Binding HaciendaKey}" Width="260"/>
                <DataGridTextColumn Header="Pago" Binding="{Binding PaymentMethod, Converter={StaticResource BusinessTextConverter}}" Width="90"/>
                <DataGridTextColumn Header="Venta" Binding="{Binding SaleStatus, Converter={StaticResource BusinessTextConverter}}" Width="95"/>
                <DataGridTextColumn Header="Hacienda" Binding="{Binding InvoiceStatus, Converter={StaticResource BusinessTextConverter}}" Width="100"/>
                <DataGridTextColumn Header="Evento" Binding="{Binding FiscalEventStatus, Converter={StaticResource BusinessTextConverter}}" Width="120"/>
                <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat=₡{0:N2}}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1.5*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Detalle" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,8"/>
            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding Items}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      Margin="0,0,10,0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Producto" Binding="{Binding ProductName}" Width="*"/>
                    <DataGridTextColumn Header="Cant." Binding="{Binding Quantity}" Width="80"/>
                    <DataGridTextColumn Header="Precio" Binding="{Binding UnitPrice, StringFormat=₡{0:N2}}" Width="100"/>
                    <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat=₡{0:N2}}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>

            <TextBlock Grid.Column="1" Text="Eventos fiscales" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,8"/>
            <DataGrid Grid.Row="1"
                      Grid.Column="1"
                      ItemsSource="{Binding FiscalEvents}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      Margin="0,0,10,0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Fecha" Binding="{Binding ReceivedAt, StringFormat=g}" Width="130"/>
                    <DataGridTextColumn Header="Estado" Binding="{Binding Status, Converter={StaticResource BusinessTextConverter}}" Width="120"/>
                    <DataGridTextColumn Header="Mensaje" Binding="{Binding Message}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <TextBlock Grid.Column="2" Text="XML fiscal" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,8"/>
            <TabControl Grid.Row="1" Grid.Column="2">
                <TabItem Header="Generado">
                    <TextBox Text="{Binding XmlRequest}" TextWrapping="NoWrap" AcceptsReturn="True" IsReadOnly="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                </TabItem>
                <TabItem Header="Firmado">
                    <TextBox Text="{Binding SignedXml}" TextWrapping="NoWrap" AcceptsReturn="True" IsReadOnly="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                </TabItem>
                <TabItem Header="Respuesta">
                    <TextBox Text="{Binding XmlResponse}" TextWrapping="NoWrap" AcceptsReturn="True" IsReadOnly="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                </TabItem>
            </TabControl>
        </Grid>

        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" Margin="0,10,0,0"/>
    </Grid>
</UserControl>
