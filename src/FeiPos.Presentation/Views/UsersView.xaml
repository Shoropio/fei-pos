<UserControl x:Class="FeiPos.Presentation.Views.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Gestion de usuarios" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,12"/>

        <Border Grid.Row="1"
                Padding="12"
                Margin="0,0,0,12"
                Background="{StaticResource AppPanelBrush}"
                BorderBrush="{StaticResource AppBorderBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="{Binding CurrentUser, StringFormat=Sesion activa: {0}}" FontWeight="Bold" Margin="0,0,0,10"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="1.1*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,8,0"
                             MinHeight="34"
                             ToolTip="Usuario"/>
                    <TextBox Grid.Column="1"
                             Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,8,0"
                             MinHeight="34"
                             ToolTip="Nombre completo"/>
                    <ComboBox Grid.Column="2"
                              ItemsSource="{Binding Roles}"
                              SelectedItem="{Binding Role, UpdateSourceTrigger=PropertyChanged}"
                              Margin="0,0,8,0"
                              MinHeight="34"/>
                    <PasswordBox x:Name="PasswordInput"
                                 Grid.Column="3"
                                 PasswordChanged="PasswordInput_PasswordChanged"
                                 Margin="0,0,8,0"
                                 MinHeight="34"
                                 ToolTip="Contrasena"/>
                    <WrapPanel Grid.Column="4">
                        <Button Content="Nuevo" Command="{Binding ClearFormCommand}" Margin="0,0,8,0"/>
                        <Button Content="Agregar" Command="{Binding AddUserCommand}" Margin="0,0,8,0"/>
                        <Button Content="Guardar" Command="{Binding SaveSelectedCommand}" Margin="0,0,8,0"/>
                        <Button Content="Reset clave" Command="{Binding ResetPasswordCommand}" Margin="0,0,8,0"/>
                        <Button Content="Activar/Inactivar" Command="{Binding ToggleActiveCommand}"/>
                    </WrapPanel>
                </Grid>
            </Grid>
        </Border>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Users}"
                  SelectedItem="{Binding SelectedUser}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Usuario" Binding="{Binding UserName}" Width="160"/>
                <DataGridTextColumn Header="Nombre" Binding="{Binding FullName}" Width="*"/>
                <DataGridTextColumn Header="Rol" Binding="{Binding Role}" Width="120"/>
                <DataGridCheckBoxColumn Header="Activo" Binding="{Binding IsActive}" Width="80"/>
                <DataGridCheckBoxColumn Header="Actual" Binding="{Binding IsCurrent}" Width="80"/>
                <DataGridTextColumn Header="Ultimo acceso" Binding="{Binding LastLoginAt, StringFormat=g}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" Margin="0,10,0,0"/>
    </Grid>
</UserControl>
