<UserControl x:Class="FeiPos.Presentation.Views.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Usuario" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,12"/>
        <Border Grid.Row="1" Padding="12" Margin="0,0,0,12" Background="{StaticResource AppPanelBrush}">
            <StackPanel>
                <TextBlock Text="{Binding CurrentUser, StringFormat=Usuario activo: {0}}" FontWeight="Bold" Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal">
                    <TextBox Width="140" Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                    <TextBox Width="220" Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                    <TextBox Width="120" Text="{Binding Role, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                    <Button Content="Agregar" Command="{Binding AddUserCommand}" Margin="0,0,8,0"/>
                    <Button Content="Iniciar sesión" Command="{Binding SetCurrentCommand}" Margin="0,0,8,0"/>
                    <Button Content="Cerrar sesión" Command="{Binding LogoutCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>
        <DataGrid Grid.Row="2" ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedUser}" AutoGenerateColumns="False" IsReadOnly="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Usuario" Binding="{Binding UserName}" Width="160"/>
                <DataGridTextColumn Header="Nombre" Binding="{Binding FullName}" Width="*"/>
                <DataGridTextColumn Header="Rol" Binding="{Binding Role}" Width="140"/>
                <DataGridCheckBoxColumn Header="Activo" Binding="{Binding IsActive}" Width="80"/>
                <DataGridCheckBoxColumn Header="Actual" Binding="{Binding IsCurrent}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>
        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" Margin="0,10,0,0"/>
    </Grid>
</UserControl>
