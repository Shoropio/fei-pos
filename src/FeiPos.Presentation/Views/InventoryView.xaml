<UserControl x:Class="FeiPos.Presentation.Views.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="340" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,20,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="Gestión de Productos" Style="{StaticResource TitleTextBlockStyle}" />
                <ui:AppBarButton Label="Nuevo Producto" Icon="Add" Margin="20,0,0,0" Command="{Binding AddProductCommand}"/>
            </StackPanel>

            <DataGrid Grid.Row="1" ItemsSource="{Binding Products}"
                      SelectedItem="{Binding SelectedProduct}"
                      AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="Activo" Binding="{Binding IsActive}" Width="65"/>
                    <DataGridTextColumn Header="SKU" Binding="{Binding Sku}" Width="90"/>
                    <DataGridTextColumn Header="Grupo" Binding="{Binding GroupName}" Width="120"/>
                    <DataGridTextColumn Header="Nombre" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Precio" Binding="{Binding Price, StringFormat=₡{0:N2}}" Width="100"/>
                    <DataGridTextColumn Header="Stock" Binding="{Binding Stock}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <Border Grid.Column="1" Background="{StaticResource AppPanelBrush}"
                CornerRadius="0" Padding="15" Visibility="{Binding SelectedProduct, Converter={StaticResource NullToVisibilityConverter}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Producto POS" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,15"/>

                    <TextBlock Text="Nombre" Margin="0,8,0,4"/>
                    <TextBox Text="{Binding SelectedProduct.Name, UpdateSourceTrigger=PropertyChanged}"/>

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,5,0">
                            <TextBlock Text="SKU" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding SelectedProduct.Sku, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" Opacity="0.7"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="5,0,0,0">
                            <TextBlock Text="Grupo" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding SelectedProduct.GroupName, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Código de barras" Margin="0,8,0,4"/>
                    <TextBox Text="{Binding SelectedProduct.Barcode, UpdateSourceTrigger=PropertyChanged}"/>

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,5,0">
                            <TextBlock Text="Unidad" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding SelectedProduct.UnitOfMeasure, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="5,0,0,0">
                            <TextBlock Text="Cantidad default" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding SelectedProduct.DefaultQuantity, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,5,0">
                            <TextBlock Text="Precio" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding SelectedProduct.Price, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="5,0,0,0">
                            <TextBlock Text="IVA (%)" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding SelectedProduct.TaxRate, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,5,0">
                            <TextBlock Text="Stock" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding SelectedProduct.Stock, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="5,0,0,0">
                            <TextBlock Text="Color visual" Margin="0,0,0,4"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding SelectedProduct.ColorHex, UpdateSourceTrigger=PropertyChanged}"/>
                                <Button Grid.Column="1" Width="32" Height="32" Margin="5,0,0,0" 
                                        Background="{Binding SelectedProduct.ColorHex}" 
                                        BorderBrush="{StaticResource AppBorderBrush}" 
                                        BorderThickness="1" Padding="0">
                                    <ui:FlyoutService.Flyout>
                                        <ui:Flyout>
                                            <StackPanel Width="200">
                                                <TextBlock Text="Seleccionar color" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                                <UniformGrid Columns="5">
                                                    <!-- Paleta de colores predefinida -->
                                                    <Button Background="#455A64" Width="30" Height="30" Margin="2" Command="{Binding DataContext.SetProductColorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="#455A64"/>
                                                    <Button Background="#D32F2F" Width="30" Height="30" Margin="2" Command="{Binding DataContext.SetProductColorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="#D32F2F"/>
                                                    <Button Background="#C2185B" Width="30" Height="30" Margin="2" Command="{Binding DataContext.SetProductColorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="#C2185B"/>
                                                    <Button Background="#7B1FA2" Width="30" Height="30" Margin="2" Command="{Binding DataContext.SetProductColorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="#7B1FA2"/>
                                                    <Button Background="#512DA8" Width="30" Height="30" Margin="2" Command="{Binding DataContext.SetProductColorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="#512DA8"/>
                                                    <Button Background="#303F9F" Width="30" Height="30" Margin="2" Command="{Binding DataContext.SetProductColorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="#303F9F"/>
                                                    <Button Background="#1976D2" Width="30" Height="30" Margin="2" Command="{Binding DataContext.SetProductColorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="#1976D2"/>
                                                    <Button Background="#0288D1" Width="30" Height="30" Margin="2" Command="{Binding DataContext.SetProductColorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="#0288D1"/>
                                                    <Button Background="#0097A7" Width="30" Height="30" Margin="2" Command="{Binding DataContext.SetProductColorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="#0097A7"/>
                                                    <Button Background="#00796B" Width="30" Height="30" Margin="2" Command="{Binding DataContext.SetProductColorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="#00796B"/>
                                                    <Button Background="#388E3C" Width="30" Height="30" Margin="2" Command="{Binding DataContext.SetProductColorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="#388E3C"/>
                                                    <Button Background="#689F38" Width="30" Height="30" Margin="2" Command="{Binding DataContext.SetProductColorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="#689F38"/>
                                                    <Button Background="#AFB42B" Width="30" Height="30" Margin="2" Command="{Binding DataContext.SetProductColorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="#AFB42B"/>
                                                    <Button Background="#FBC02D" Width="30" Height="30" Margin="2" Command="{Binding DataContext.SetProductColorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="#FBC02D"/>
                                                    <Button Background="#FFA000" Width="30" Height="30" Margin="2" Command="{Binding DataContext.SetProductColorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="#FFA000"/>
                                                </UniformGrid>
                                            </StackPanel>
                                        </ui:Flyout>
                                    </ui:FlyoutService.Flyout>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Imagen" Margin="0,8,0,4"/>
                    <TextBox Text="{Binding SelectedProduct.ImagePath, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Comentarios frecuentes" Margin="0,8,0,4"/>
                    <TextBox Text="{Binding SelectedProduct.Comments, UpdateSourceTrigger=PropertyChanged}"
                             MinHeight="64" TextWrapping="Wrap" AcceptsReturn="True"/>

                    <CheckBox Content="Activo en POS" IsChecked="{Binding SelectedProduct.IsActive, UpdateSourceTrigger=PropertyChanged}" Margin="0,12,0,0"/>
                    <CheckBox Content="Servicio sin control de stock" IsChecked="{Binding SelectedProduct.IsService, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,0"/>

                    <Button Content="Guardar Cambios" Style="{StaticResource AccentButtonStyle}"
                            HorizontalAlignment="Stretch" Margin="0,20,0,0"
                            Command="{Binding SaveChangesCommand}"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
