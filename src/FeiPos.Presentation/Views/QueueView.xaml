<UserControl x:Class="FeiPos.Presentation.Views.QueueView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="Monitor de Comprobantes" Style="{StaticResource TitleTextBlockStyle}" VerticalAlignment="Center"/>
            <ui:AppBarButton Label="Actualizar" Icon="Refresh" Margin="20,0,0,0" Command="{Binding RefreshCommand}"/>
        </StackPanel>

        <DataGrid Grid.Row="1" ItemsSource="{Binding Responses}" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Fecha" Binding="{Binding ReceivedAt, StringFormat=g}" Width="150"/>
                <DataGridTextColumn Header="Clave Hacienda" Binding="{Binding Key}" Width="*"/>
                <DataGridTemplateColumn Header="Estado" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Status}" 
                                       FontWeight="Bold" 
                                       Foreground="{DynamicResource SystemAccentColorBrush}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Mensaje" Binding="{Binding Message}" Width="2*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
