<UserControl x:Class="FeiPos.Presentation.Views.CreditAccountsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="150"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Pagos de credito" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,12"/>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBox Width="120" Text="{Binding PaymentAmount, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
            <TextBox Width="260" Text="{Binding PaymentReference, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
            <Button Content="Registrar abono" Command="{Binding AddPaymentCommand}" Margin="0,0,8,0"/>
            <Button Content="Actualizar" Command="{Binding LoadAccountsCommand}"/>
        </StackPanel>
        <DataGrid Grid.Row="2" ItemsSource="{Binding Accounts}" SelectedItem="{Binding SelectedAccount}" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Cliente" Binding="{Binding CustomerName}" Width="*"/>
                <DataGridTextColumn Header="Credito" Binding="{Binding CreditTotal, StringFormat=₡{0:N2}}" Width="120"/>
                <DataGridTextColumn Header="Pagado" Binding="{Binding PaidTotal, StringFormat=₡{0:N2}}" Width="120"/>
                <DataGridTextColumn Header="Saldo" Binding="{Binding Balance, StringFormat=₡{0:N2}}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
        <DataGrid Grid.Row="3" ItemsSource="{Binding Payments}" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,12,0,0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Fecha" Binding="{Binding CreatedAt, StringFormat=g}" Width="160"/>
                <DataGridTextColumn Header="Monto" Binding="{Binding Amount, StringFormat=₡{0:N2}}" Width="120"/>
                <DataGridTextColumn Header="Referencia" Binding="{Binding Reference}" Width="*"/>
                <DataGridTextColumn Header="Usuario" Binding="{Binding UserName}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
        <TextBlock Grid.Row="4" Text="{Binding StatusMessage}" Margin="0,10,0,0"/>
    </Grid>
</UserControl>
