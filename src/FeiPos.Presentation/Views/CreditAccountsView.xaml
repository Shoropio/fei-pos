<UserControl x:Class="FeiPos.Presentation.Views.CreditAccountsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Cuentas por Cobrar" Style="{StaticResource TitleTextBlockStyle}"/>
                <TextBlock Text="Gestión de créditos y abonos de clientes" Foreground="{StaticResource AppMutedTextBrush}" Margin="0,5,0,0"/>
            </StackPanel>
            
            <Button Grid.Column="1" Content="Actualizar" Command="{Binding LoadAccountsCommand}" 
                    VerticalAlignment="Center" Padding="15,8"/>
        </Grid>

        <!-- Main Content (2 Columns) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="6*"/>
                <ColumnDefinition Width="4*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Accounts List -->
            <GroupBox Header="Cuentas Activas" Margin="0,0,10,0">
                <DataGrid ItemsSource="{Binding Accounts}" 
                          SelectedItem="{Binding SelectedAccount}" 
                          AutoGenerateColumns="False" 
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          SelectionMode="Single"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{StaticResource AppBorderBrush}"
                          Background="Transparent"
                          RowBackground="Transparent"
                          BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Cliente" Binding="{Binding CustomerName}" Width="*"/>
                        <DataGridTextColumn Header="Total Crédito" Binding="{Binding CreditTotal, StringFormat=₡{0:N2}}" Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right" />
                                    <Setter Property="Margin" Value="0,0,10,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Abonado" Binding="{Binding PaidTotal, StringFormat=₡{0:N2}}" Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right" />
                                    <Setter Property="Foreground" Value="{StaticResource AppAccentGreenBrush}"/>
                                    <Setter Property="Margin" Value="0,0,10,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Saldo Pendiente" Binding="{Binding Balance, StringFormat=₡{0:N2}}" Width="130">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right" />
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="#FFA07A"/>
                                    <Setter Property="Margin" Value="0,0,10,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <!-- Right: Payment Entry & History -->
            <Grid Grid.Column="1" Margin="10,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <GroupBox Header="Registrar Abono" Grid.Row="0" Margin="0,0,0,20">
                    <StackPanel Margin="10">
                        <!-- Selected Account Info -->
                        <Border Background="{StaticResource AppPanelAltBrush}" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" Padding="15" Margin="0,0,0,15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Cliente Seleccionado:" Foreground="{StaticResource AppMutedTextBrush}" FontSize="12"/>
                                <TextBlock Grid.Row="1" Text="{Binding SelectedAccount.CustomerName, FallbackValue='-- Ninguno --'}" 
                                           FontWeight="SemiBold" FontSize="16" Margin="0,5,0,0" TextWrapping="Wrap"/>
                                           
                                <StackPanel Grid.Row="1" HorizontalAlignment="Right">
                                    <TextBlock Text="Saldo:" Foreground="{StaticResource AppMutedTextBrush}" FontSize="12" HorizontalAlignment="Right"/>
                                    <TextBlock Text="{Binding SelectedAccount.Balance, FallbackValue='₡0.00', StringFormat=₡{0:N2}}" 
                                               FontWeight="Bold" FontSize="16" Foreground="#FFA07A" HorizontalAlignment="Right"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <TextBlock Text="Monto a abonar (₡)" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding PaymentAmount, UpdateSourceTrigger=PropertyChanged}" 
                                 FontSize="18" FontWeight="SemiBold"
                                 Padding="10,8" Margin="0,0,0,15"
                                 HorizontalContentAlignment="Right"/>

                        <TextBlock Text="Referencia / Comprobante" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding PaymentReference, UpdateSourceTrigger=PropertyChanged}" 
                                 Padding="10,8" Margin="0,0,0,20"/>

                        <Button Content="Aplicar Abono" Command="{Binding AddPaymentCommand}" 
                                Style="{StaticResource AccentButtonStyle}" 
                                HorizontalAlignment="Stretch" Height="45"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Historial de Pagos del Cliente" Grid.Row="1">
                    <DataGrid ItemsSource="{Binding Payments}" 
                              AutoGenerateColumns="False" 
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{StaticResource AppBorderBrush}"
                              Background="Transparent"
                              RowBackground="Transparent"
                              BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Fecha" Binding="{Binding CreatedAt, StringFormat=dd/MM/yyyy HH:mm}" Width="130"/>
                            <DataGridTextColumn Header="Monto" Binding="{Binding Amount, StringFormat=₡{0:N2}}" Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right" />
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Foreground" Value="{StaticResource AppAccentGreenBrush}"/>
                                        <Setter Property="Margin" Value="0,0,10,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Referencia" Binding="{Binding Reference}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>
            </Grid>
        </Grid>

        <!-- Status -->
        <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" 
                   Foreground="{StaticResource AppAccentBrush}" 
                   FontWeight="SemiBold" Margin="0,15,0,0"/>
    </Grid>
</UserControl>
