<UserControl x:Class="FeiPos.Presentation.Views.BackupsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,30">
            <TextBlock Text="Copias de Seguridad" Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock Text="Respalda toda la informacion de tu negocio (Inventario, Ventas, Clientes y Configuracion)" 
                       Foreground="{StaticResource AppMutedTextBrush}" Margin="0,5,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Background="{StaticResource AppPanelBrush}" BorderBrush="{StaticResource AppBorderBrush}" 
                BorderThickness="1" CornerRadius="0" Padding="30" MaxWidth="600" HorizontalAlignment="Left">
            <StackPanel>
                <TextBlock Text="Respaldo Manual" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <TextBlock Text="Genera un archivo ZIP con la base de datos completa. Este archivo lo puedes guardar en una llave USB o en la nube (Google Drive, OneDrive)." 
                           TextWrapping="Wrap" Foreground="{StaticResource AppMutedTextBrush}" Margin="0,0,0,20"/>
                
                <Button Content="Crear respaldo" 
                        Command="{Binding CreateBackupCommand}" 
                        Style="{StaticResource AccentButtonStyle}"
                        Width="200" Height="45" HorizontalAlignment="Left"
                        IsEnabled="{Binding IsNotWorking}"/>

                <TextBlock Text="{Binding StatusMessage}" 
                           Foreground="#4CAF50" FontWeight="SemiBold" TextWrapping="Wrap"
                           Margin="0,20,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="{StaticResource AppPanelBrush}" BorderBrush="{StaticResource AppBorderBrush}" 
                BorderThickness="1" CornerRadius="0" Padding="30" MaxWidth="600" HorizontalAlignment="Left" Margin="0,20,0,0">
            <StackPanel>
                <TextBlock Text="Restaurar respaldo" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <TextBlock Text="Carga un archivo ZIP previo para recuperar toda la información. ATENCIÓN: Esto reemplazará los datos actuales y la aplicación se cerrará." 
                           TextWrapping="Wrap" Foreground="#FFA07A" Margin="0,0,0,20"/>
                
                <Button Content="Restaurar datos" 
                        Command="{Binding RestoreBackupCommand}" 
                        Style="{StaticResource AccentButtonStyle}" Background="#C62828"
                        Width="200" Height="45" HorizontalAlignment="Left"
                        IsEnabled="{Binding IsNotWorking}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
