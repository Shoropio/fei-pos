<Window x:Class="FeiPos.Presentation.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fei POS - Acceso"
        Height="430"
        Width="460"
        Icon="/Assets/feipos.ico"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource AppBackgroundBrush}">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Fei POS" Style="{StaticResource TitleTextBlockStyle}" FontSize="30"/>
            <TextBlock Text="Inicio de sesion" Foreground="{StaticResource AppMutedTextBrush}" Margin="0,4,0,0"/>
        </StackPanel>

        <Border Grid.Row="1"
                Background="{StaticResource AppPanelBrush}"
                BorderBrush="{StaticResource AppBorderBrush}"
                BorderThickness="1"
                CornerRadius="0"
                Padding="18"
                Margin="0,20,0,14">
            <StackPanel>
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPasswordChangeRequired}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Usuario" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}"
                             Height="34"
                             Margin="0,0,0,14"/>

                    <TextBlock Text="Contrasena" Margin="0,0,0,6"/>
                    <PasswordBox x:Name="PasswordInput"
                                 Height="34"
                                 PasswordChar="*"
                                 KeyDown="PasswordInput_KeyDown"/>
                </StackPanel>

                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPasswordChangeRequired}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Nueva contrasena" Margin="0,0,0,6"/>
                    <PasswordBox x:Name="NewPasswordInput"
                                 Height="34"
                                 PasswordChar="*"
                                 Margin="0,0,0,14"/>

                    <TextBlock Text="Confirmar contrasena" Margin="0,0,0,6"/>
                    <PasswordBox x:Name="ConfirmPasswordInput"
                                 Height="34"
                                 PasswordChar="*"
                                 KeyDown="PasswordInput_KeyDown"/>
                </StackPanel>

                <TextBlock Text="Acceso inicial: admin / admin123"
                           Foreground="{StaticResource AppMutedTextBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,20,0,0"/>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="#FFA07A" FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Salir" Click="CancelButton_Click" Margin="0,0,8,0"/>
            <Button Content="Entrar / Continuar" Style="{StaticResource AccentButtonStyle}" Click="LoginButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
