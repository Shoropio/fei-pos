<UserControl x:Class="FeiPos.Presentation.Views.CashDrawerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Depósitos / Retiros" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,12"/>
        <Border Grid.Row="1" Padding="12" Margin="0,0,0,12" Background="{StaticResource AppPanelBrush}" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*" MinWidth="180"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0" ItemsSource="{Binding EntryTypes}" SelectedItem="{Binding SelectedType}" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1" Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                <TextBox Grid.Column="2" Text="{Binding Reason, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                <Button Grid.Column="3" Content="Registrar" Command="{Binding AddEntryCommand}"/>
            </Grid>
        </Border>
        <DataGrid Grid.Row="2" ItemsSource="{Binding Entries}" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Fecha" Binding="{Binding CreatedAt, StringFormat=g}" Width="160"/>
                <DataGridTextColumn Header="Tipo" Binding="{Binding Type, Converter={StaticResource BusinessTextConverter}}" Width="120"/>
                <DataGridTextColumn Header="Monto" Binding="{Binding Amount, StringFormat=₡{0:N2}}" Width="120"/>
                <DataGridTextColumn Header="Motivo" Binding="{Binding Reason}" Width="*"/>
                <DataGridTextColumn Header="Usuario" Binding="{Binding UserName}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
        <WrapPanel Grid.Row="3" Margin="0,10,0,0">
            <TextBlock Text="{Binding DepositsTotal, StringFormat=Depósitos: ₡{0:N2}}" Margin="0,0,20,0"/>
            <TextBlock Text="{Binding WithdrawalsTotal, StringFormat=Retiros: ₡{0:N2}}" Margin="0,0,20,0"/>
            <TextBlock Text="{Binding StatusMessage}"/>
        </WrapPanel>
    </Grid>
</UserControl>
