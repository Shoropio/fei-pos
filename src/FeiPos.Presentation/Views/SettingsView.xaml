<UserControl x:Class="FeiPos.Presentation.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019">

    <ScrollViewer Margin="20" VerticalScrollBarVisibility="Auto">
        <StackPanel HorizontalAlignment="Stretch">
            <TextBlock Text="Configuración del Sistema" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,25"/>

            <WrapPanel Orientation="Horizontal">

                <!-- ========== DATOS DEL NEGOCIO ========== -->
                <GroupBox Header="Datos del Negocio" Margin="0,0,20,20" Width="500">
                    <StackPanel Margin="10">
                        <TextBlock Text="Nombre del Comercio" Margin="0,10,0,5"/>
                        <TextBox Text="{Binding Config.CompanyName, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="Cédula Física / Jurídica" Margin="0,10,0,5"/>
                        <TextBox Text="{Binding Config.TaxId, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="Correo Electrónico" Margin="0,10,0,5"/>
                        <TextBox Text="{Binding Config.Email, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="Teléfono" Margin="0,10,0,5"/>
                        <TextBox Text="{Binding Config.Phone, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="Actividad Económica" Margin="0,10,0,5"/>
                        <TextBox Text="{Binding Config.EconomicActivity, UpdateSourceTrigger=PropertyChanged}"/>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,5,0">
                                <TextBlock Text="N° de Local" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding Config.OfficeId, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                <TextBlock Text="N° de Terminal" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding Config.TerminalId, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!-- ========== HACIENDA / ATV ========== -->
                <GroupBox Header="Hacienda / ATV" Margin="0,0,20,20" Width="500">
                    <StackPanel Margin="10">
                        <Grid Margin="0,10,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Modo Sandbox (Pruebas)" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            <CheckBox Grid.Column="1" IsChecked="{Binding Config.UseSandbox}" 
                                      Content="Activar" VerticalAlignment="Center"/>
                        </Grid>

                        <Border Background="#1A3A1A" BorderBrush="#2D5A2D" BorderThickness="1" Padding="8" Margin="0,0,0,10"
                                Visibility="{Binding Config.UseSandbox, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="⚠ Modo pruebas activo — las facturas se envían a Hacienda SANDBOX"
                                       Foreground="#6FCF6F" TextWrapping="Wrap" FontSize="11"/>
                        </Border>

                        <TextBlock Text="Usuario ATV (Comprobantes Electrónicos)" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding Config.ApiUsername, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="Contraseña ATV" Margin="0,10,0,5"/>
                        <PasswordBox x:Name="ApiPasswordBox" PasswordChanged="ApiPasswordBox_Changed"/>
                    </StackPanel>
                </GroupBox>

                <!-- ========== FIRMA DIGITAL ========== -->
                <GroupBox Header="Firma Digital (.p12)" Margin="0,0,20,20" Width="500">
                    <StackPanel Margin="10">
                        <TextBlock Text="Ruta del Certificado" Margin="0,10,0,5"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding Config.CertificatePath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True"/>
                            <Button Grid.Column="1" Content="Buscar..." 
                                    Command="{Binding BrowseCertificateCommand}"
                                    Margin="5,0,0,0"/>
                        </Grid>

                        <TextBlock Text="PIN del Certificado" Margin="0,15,0,5"/>
                        <PasswordBox x:Name="CertPinBox" PasswordChanged="CertPinBox_Changed"/>

                        <Border Background="#151515" BorderBrush="#3A3A3A" BorderThickness="1" 
                                Padding="10" Margin="0,15,0,0" CornerRadius="0">
                            <StackPanel>
                                <TextBlock Text="Estado del Certificado" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBlock x:Name="CertStatusText" Text="Sin certificado configurado" 
                                           Foreground="#888" TextWrapping="Wrap" FontSize="11"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </GroupBox>

                <!-- ========== IMPRESORA ========== -->
                <GroupBox Header="Impresora Térmica (ESC/POS)" Margin="0,0,20,20" Width="500">
                    <StackPanel Margin="10">
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Seleccionar Impresora" Margin="0,0,0,5" 
                                       Grid.ColumnSpan="2"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox ItemsSource="{Binding AvailablePrinters}"
                                      SelectedItem="{Binding Config.PrinterName}"
                                      IsEditable="True"
                                      Text="{Binding Config.PrinterName, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="1" Content="Recargar" ToolTip="Recargar impresoras"
                                    Command="{Binding RefreshPrintersCommand}"
                                    Width="36" Margin="5,0,0,0"/>
                        </Grid>

                        <Grid Margin="0,15,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Content="Imprimir recibo automáticamente"
                                      IsChecked="{Binding Config.AutoPrintReceipt}"
                                      VerticalAlignment="Center"/>
                            <CheckBox Grid.Column="1" Content="Abrir gaveta al cobrar"
                                      IsChecked="{Binding Config.OpenDrawerOnSale}"
                                      VerticalAlignment="Center"/>
                        </Grid>

                        <Button Content="🖨  Imprimir Test"
                                Command="{Binding PrintTestCommand}"
                                HorizontalAlignment="Left"
                                Margin="0,20,0,0"
                                Padding="20,8"/>
                    </StackPanel>
                </GroupBox>

            </WrapPanel>

            <!-- STATUS + GUARDAR -->
            <TextBlock Text="{Binding StatusMessage}" 
                       Foreground="{StaticResource AppAccentBrush}"
                       FontWeight="SemiBold"
                       Margin="0,0,0,10"/>
            <Button Content="Guardar Configuración" Style="{StaticResource AccentButtonStyle}"
                    Height="45" Width="300" HorizontalAlignment="Left" Margin="0,0,0,40"
                    Command="{Binding SaveCommand}"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
