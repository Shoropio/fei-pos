<Window x:Class="FeiPos.Presentation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        Title="Fei POS - Sistema de Punto de Venta" Height="768" Width="1024"
        ui:WindowHelper.UseModernWindowStyle="True">
    
    <Grid>
        <ui:NavigationView x:Name="NavView"
                         PaneDisplayMode="LeftMinimal"
                         IsPaneOpen="False"
                         CompactPaneLength="0"
                         OpenPaneLength="260"
                         IsSettingsVisible="False"
                         Header="Fei POS"
                         SelectionChanged="NavView_SelectionChanged">
            <ui:NavigationView.Resources>
                <Style TargetType="{x:Type ui:NavigationViewItem}">
                    <Setter Property="MinHeight" Value="40"/>
                </Style>
            </ui:NavigationView.Resources>

            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Icon="Home" Tag="Dashboard">
                    <TextBlock Text="Dashboard" Margin="20,0,0,0"/>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Icon="Shop" Tag="Sales">
                    <TextBlock Text="Punto de Venta" Margin="20,0,0,0"/>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Icon="AllApps" Tag="Inventory">
                    <TextBlock Text="Inventario" Margin="20,0,0,0"/>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Icon="People" Tag="Customers">
                    <TextBlock Text="Clientes" Margin="20,0,0,0"/>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Icon="FourBars" Tag="Reports">
                    <TextBlock Text="Monitor Fiscal" Margin="20,0,0,0"/>
                </ui:NavigationViewItem>
            </ui:NavigationView.MenuItems>
            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItem Icon="Setting" Tag="Settings">
                    <TextBlock Text="Configuración" Margin="20,0,0,0"/>
                </ui:NavigationViewItem>
            </ui:NavigationView.FooterMenuItems>

            <ContentControl x:Name="ContentFrame" Margin="12">
                <Grid>
                    <TextBlock Text="Bienvenido al Sistema POS Empresarial" 
                               Style="{StaticResource TitleTextBlockStyle}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </ContentControl>
        </ui:NavigationView>
    </Grid>
</Window>
