<Window x:Class="FeiPos.Presentation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        Title="Fei POS - Sistema de Punto de Venta" Height="768" Width="1024"
        ui:WindowHelper.UseModernWindowStyle="True">
    
    <Grid>
        <ui:NavigationView x:Name="NavView"
                         PaneDisplayMode="LeftMinimal"
                         IsPaneOpen="False"
                         CompactPaneLength="0"
                         OpenPaneLength="260"
                         IsSettingsVisible="True"
                         Header="Fei POS"
                         SelectionChanged="NavView_SelectionChanged">
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="Dashboard" Icon="Home" Tag="Dashboard" />
                <ui:NavigationViewItem Content="Punto de Venta" Icon="Shop" Tag="Sales" />
                <ui:NavigationViewItem Content="Inventario" Icon="AllApps" Tag="Inventory" />
                <ui:NavigationViewItem Content="Clientes" Icon="People" Tag="Customers" />
                <ui:NavigationViewItem Content="Monitor Fiscal" Icon="FourBars" Tag="Reports" />
            </ui:NavigationView.MenuItems>

            <ContentControl x:Name="ContentFrame" Margin="12">
                <Grid>
                    <TextBlock Text="Bienvenido al Sistema POS Empresarial" 
                               Style="{StaticResource TitleTextBlockStyle}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </ContentControl>
        </ui:NavigationView>
    </Grid>
</Window>
