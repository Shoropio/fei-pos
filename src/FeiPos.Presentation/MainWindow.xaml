<Window x:Class="FeiPos.Presentation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        Title="Fei POS - Sistema de Punto de Venta"
        Height="768"
        Width="1366"
        Icon="Assets/feipos.ico"
        Background="#252525"
        WindowStyle="None"
        WindowState="Maximized"
        KeyDown="Window_KeyDown"
        ui:WindowHelper.UseModernWindowStyle="False">
    
    <Grid Background="#252525">
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.Resources>
            <Style x:Key="WindowControlButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="42"/>
                <Setter Property="Height" Value="32"/>
                <Setter Property="Margin" Value="0"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Background" Value="#202020"/>
                <Setter Property="BorderBrush" Value="#3A3A3A"/>
                <Setter Property="BorderThickness" Value="0,0,1,1"/>
            </Style>
        </Grid.Resources>

        <ui:NavigationView x:Name="NavView"
                         Grid.Row="1"
                         Background="#252525"
                         Foreground="White"
                         PaneDisplayMode="LeftMinimal"
                         IsPaneOpen="False"
                         CompactPaneLength="0"
                         OpenPaneLength="260"
                         IsSettingsVisible="False"
                         SelectionChanged="NavView_SelectionChanged">
            <ui:NavigationView.Header>
                <TextBlock Text="Fei POS" Foreground="White"/>
            </ui:NavigationView.Header>
            <ui:NavigationView.Resources>
                <Style TargetType="{x:Type ui:NavigationViewItem}">
                    <Setter Property="MinHeight" Value="40"/>
                    <Setter Property="Foreground" Value="White"/>
                </Style>
            </ui:NavigationView.Resources>

            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Icon="Home" Tag="Dashboard">
                    <TextBlock Text="Dashboard" Margin="20,0,0,0"/>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Icon="Shop" Tag="Sales">
                    <TextBlock Text="Punto de Venta" Margin="20,0,0,0"/>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Icon="AllApps" Tag="Inventory">
                    <TextBlock Text="Inventario" Margin="20,0,0,0"/>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Icon="People" Tag="Customers">
                    <TextBlock Text="Clientes" Margin="20,0,0,0"/>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Icon="FourBars" Tag="Reports">
                    <TextBlock Text="Monitor Fiscal" Margin="20,0,0,0"/>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Icon="List" Tag="SalesHistory">
                    <TextBlock Text="Historial ventas" Margin="20,0,0,0"/>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Icon="Document" Tag="FiscalInvoices">
                    <TextBlock Text="Facturas" Margin="20,0,0,0"/>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Icon="Library" Tag="OpenOrders">
                    <TextBlock Text="Ventas abiertas" Margin="20,0,0,0"/>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Icon="Download" Tag="CashDrawer">
                    <TextBlock Text="Depósitos / Retiros" Margin="20,0,0,0"/>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Icon="Contact" Tag="CreditAccounts">
                    <TextBlock Text="Créditos" Margin="20,0,0,0"/>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Icon="Calendar" Tag="DayClose">
                    <TextBlock Text="Finalizar día" Margin="20,0,0,0"/>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Icon="People" Tag="Users">
                    <TextBlock Text="Usuarios" Margin="20,0,0,0"/>
                </ui:NavigationViewItem>
            </ui:NavigationView.MenuItems>
            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItem Icon="Setting" Tag="Settings">
                    <TextBlock Text="Configuración" Margin="20,0,0,0"/>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Icon="SaveLocal" Tag="Backups">
                    <TextBlock Text="Copias de Seguridad" Margin="20,0,0,0"/>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Icon="LeaveChat" Tag="Logout">
                    <TextBlock Text="Cerrar sesion" Margin="20,0,0,0"/>
                </ui:NavigationViewItem>
            </ui:NavigationView.FooterMenuItems>

            <ContentControl x:Name="ContentFrame" Margin="12">
                <Grid>
                    <TextBlock Text="Bienvenido al Sistema POS Empresarial" 
                               Style="{StaticResource TitleTextBlockStyle}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </ContentControl>
        </ui:NavigationView>

        <Border Grid.Row="0"
                Background="#101010"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <TextBlock Text="Fei POS - Sistema de Punto de Venta"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"
                           FontSize="12"/>
                <TextBlock x:Name="SessionText"
                           Foreground="#B8B8B8"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Margin="0,0,184,0"
                           FontSize="12"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Orientation="Horizontal"
                    Panel.ZIndex="10">
            <Button Content="_"
                    ToolTip="Minimizar"
                    Click="MinimizeButton_Click"
                    Style="{StaticResource WindowControlButtonStyle}"/>
            <Button Content="□"
                    ToolTip="Maximizar / restaurar"
                    Click="MaximizeButton_Click"
                    Style="{StaticResource WindowControlButtonStyle}"/>
            <Button Content="⛶"
                    ToolTip="Pantalla completa"
                    Click="FullScreenButton_Click"
                    Style="{StaticResource WindowControlButtonStyle}"/>
            <Button Content="X"
                    ToolTip="Cerrar"
                    Click="CloseButton_Click"
                    Style="{StaticResource WindowControlButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>
