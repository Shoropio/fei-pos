<Application x:Class="FeiPos.Presentation.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:converters="clr-namespace:FeiPos.Presentation.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemeResources />
                <ui:XamlControlsResources />
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
            <converters:BusinessTextConverter x:Key="BusinessTextConverter" />

            <SolidColorBrush x:Key="AppBackgroundBrush" Color="#252525"/>
            <SolidColorBrush x:Key="AppPanelBrush" Color="#303030"/>
            <SolidColorBrush x:Key="AppPanelAltBrush" Color="#1F1F1F"/>
            <SolidColorBrush x:Key="AppBorderBrush" Color="#4A4A4A"/>
            <SolidColorBrush x:Key="AppAccentBrush" Color="#16A4D8"/>
            <SolidColorBrush x:Key="AppAccentGreenBrush" Color="#3F9348"/>
            <SolidColorBrush x:Key="AppTextBrush" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="AppMutedTextBrush" Color="#B8B8B8"/>
            <SolidColorBrush x:Key="AppSelectedBrush" Color="#16639A"/>

            <Style TargetType="UserControl">
                <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
            </Style>

            <Style x:Key="TitleTextBlockStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
                <Setter Property="FontSize" Value="24"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>

            <Style x:Key="SubtitleTextBlockStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
                <Setter Property="FontSize" Value="20"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>

            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
            </Style>

            <Style TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
                <Setter Property="Background" Value="{StaticResource AppPanelAltBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="12,7"/>
            </Style>

            <Style TargetType="TextBox">
                <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
                <Setter Property="Background" Value="{StaticResource AppPanelAltBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}"/>
                <Setter Property="SelectionBrush" Value="{StaticResource AppAccentBrush}"/>
                <Setter Property="Padding" Value="8,5"/>
            </Style>

            <Style TargetType="PasswordBox">
                <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
                <Setter Property="Background" Value="{StaticResource AppPanelAltBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}"/>
                <Setter Property="SelectionBrush" Value="{StaticResource AppAccentBrush}"/>
                <Setter Property="Padding" Value="8,5"/>
            </Style>

            <Style TargetType="ComboBox">
                <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
                <Setter Property="Background" Value="{StaticResource AppPanelAltBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}"/>
                <Setter Property="Padding" Value="8,4"/>
            </Style>

            <Style TargetType="CheckBox">
                <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
            </Style>

            <Style TargetType="GroupBox">
                <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
                <Setter Property="Background" Value="{StaticResource AppPanelBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}"/>
                <Setter Property="Padding" Value="12"/>
            </Style>

            <Style TargetType="DataGrid">
                <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="GridLinesVisibility" Value="Horizontal"/>
                <Setter Property="HorizontalGridLinesBrush" Value="#3A3A3A"/>
                <Setter Property="VerticalGridLinesBrush" Value="#3A3A3A"/>
                <Setter Property="RowBackground" Value="{StaticResource AppBackgroundBrush}"/>
                <Setter Property="AlternatingRowBackground" Value="#2B2B2B"/>
                <Setter Property="HeadersVisibility" Value="Column"/>
            </Style>

            <Style TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="#111111"/>
                <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}"/>
                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                <Setter Property="Padding" Value="10,7"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>

            <Style TargetType="DataGridRow">
                <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
                <Setter Property="BorderBrush" Value="#3A3A3A"/>
                <Setter Property="BorderThickness" Value="0,0,0,1"/>
            </Style>

            <Style TargetType="DataGridCell">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="Padding" Value="10,4"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
